package org.stepdefinition;

import static org.junit.Assert.*;

import java.util.Set;

import org.pageObjects.DemoQA_BrowserWindowsPage;
import org.utility.ExtentReport;
import org.utility.UtilityClass;

import io.cucumber.java.en.*;

public class DemoQA_BrowserWindowSteps extends UtilityClass {

	// ── URLs / text loaded from config.properties ─────────────────────────────
	private static final String DEMOQA_LINKS_URL = getValueFromPropertFile("demoqa.links.url");
	private static final String NEW_TAB_EXPECTED_URL = getValueFromPropertFile("demoqa.newtab.expected.url");
//    private static final String NEW_TAB_EXPECTED_HEADING  = getValueFromPropertFile("demoqa.newtab.expected.heading");

	// ── State ─────────────────────────────────────────────────────────────────
	private DemoQA_BrowserWindowsPage page;
	private String originalWindowHandle;
	private String newTabHandle;

	@Given("user navigates to DemoQA Browser Windows page")
	public void userNavigatesToDemoQALinksPage() {
		driver.get(DEMOQA_LINKS_URL);
		originalWindowHandle = driver.getWindowHandle();
		page = new DemoQA_BrowserWindowsPage();

		ExtentReport.test.info("Step 1 – Navigated to: " + DEMOQA_LINKS_URL);
		ExtentReport.test.info("Original window handle: " + originalWindowHandle);
	}

	@Given("User clicks on {string} in the left panel")
	public void userClicksOnGroupInLeftPanel(String groupName) {
		page.clickAlertsFrameWindowsGroup();
		ExtentReport.test.info("Step 2 – Expanded accordion group: " + groupName);
	}

	@And("User clicks on {string} menu item")
	public void userClicksOnMenuItem(String menuItem) {
		page.clickBrowserWindowsMenuItem();

		String currentUrl = page.getCurrentPageUrl();
		String expectedUrlFragment = "browser-windows";

		assertTrue("Expected URL to contain '" + expectedUrlFragment + "' but was: " + currentUrl,
				currentUrl.contains(expectedUrlFragment));

		ExtentReport.test.pass("Step 3 – Navigated to Browser Windows page. URL: " + currentUrl);
	}

	@When("User clicks the {string} button")
	public void userClicksTheButton(String buttonLabel) {
		Set<String> handlesBefore = driver.getWindowHandles();

		if (buttonLabel.equalsIgnoreCase("New Tab")) {
			page.clickNewTabButton();
		}

		ExtentReport.test.info("Step 4 – Clicked button: " + buttonLabel);

		// Poll up to 5 s for the new tab handle to appear
		long deadline = System.currentTimeMillis() + 5_000;
		while (System.currentTimeMillis() < deadline) {
			Set<String> handlesAfter = driver.getWindowHandles();
			if (handlesAfter.size() > handlesBefore.size()) {
				handlesAfter.removeAll(handlesBefore);
				newTabHandle = handlesAfter.iterator().next();
				break;
			}
			try {
				Thread.sleep(300);
			} catch (InterruptedException ignored) {
			}
		}

		assertNotNull("New tab did not open within the 5-second timeout.", newTabHandle);
		ExtentReport.test.info("Step 4 – New tab detected. Handle: " + newTabHandle);
	}

	@Then("A new tab should open with the expected URL")
	public void aNewTabShouldOpenWithExpectedURL() {
		driver.switchTo().window(newTabHandle);

		String actualUrl = driver.getCurrentUrl();
		ExtentReport.test.info("Step 4 – New tab URL: " + actualUrl);

		assertEquals("New tab URL mismatch.\nExpected : " + NEW_TAB_EXPECTED_URL + "\nActual   : " + actualUrl,
				NEW_TAB_EXPECTED_URL, actualUrl);

		ExtentReport.test.pass("Step 4 – New tab opened at expected URL: " + actualUrl);
	}

	@And("The new tab should display the heading {string}")
	public void theNewTabShouldDisplayTheHeading(String expectedHeading) {
		// We are already on the new tab from the previous step
		String actualHeading = page.getSampleHeadingText();

		ExtentReport.test.info("Step 4 – New tab heading: " + actualHeading);

		assertEquals("New tab heading mismatch.\nExpected : " + expectedHeading + "\nActual   : " + actualHeading,
				expectedHeading, actualHeading);

		ExtentReport.test.pass("Step 4 – New tab heading verified: " + actualHeading);
	}

	@When("User switches back to the original tab")
	public void userSwitchesBackToOriginalTab() {
		driver.switchTo().window(originalWindowHandle);
		ExtentReport.test.info("Step 5 – Switched back to original tab. Handle: " + originalWindowHandle);
	}

	@Then("The original tab should still display the Browser Windows page")
	public void originalTabShouldDisplayBrowserWindowsPage() {
		String currentUrl = driver.getCurrentUrl();

		ExtentReport.test.info("Step 5 – Original tab URL after switch-back: " + currentUrl);

		assertTrue("Expected original tab URL to contain 'browser-windows' but was: " + currentUrl,
				currentUrl.contains("browser-windows"));

		ExtentReport.test.pass("Step 5 – Original tab still on Browser Windows page: " + currentUrl);
	}
}
