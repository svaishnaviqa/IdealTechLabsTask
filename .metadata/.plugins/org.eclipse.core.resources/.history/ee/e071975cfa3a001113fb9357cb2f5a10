package org.pageObjects;



import java.util.*;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;

public class OrangeHRM_LoginPage {
    WebDriver driver;

    public OrangeHRM_LoginPage(WebDriver driver) {
        this.driver = driver;
    }

    public List<String> getAllQuantities() {
        List<WebElement> quantities = driver.findElements(By.className("cart_quantity"));
        List<String> quantityValues = new ArrayList<>();

        for (WebElement qty : quantities) {
            quantityValues.add(qty.getText().trim());
        }

        return quantityValues;
    }

    public void removeItem(String itemName) {
        driver.findElement(By.xpath("//div[text()='" + itemName + "']/ancestor::div[@class='cart_item']//button")).click();
    }

    public void clickCheckout() {
        driver.findElement(By.id("checkout")).click();
    }
}
